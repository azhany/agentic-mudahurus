# ---- Transactional API (Go/Echo) ----
APP_ENV=development
API_HTTP_ADDR=:8080
API_LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://mudahurus:mudahurus@localhost:5432/mudahurus?sslmode=disable

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mudahurus
S3_USE_SSL=false
S3_PUBLIC_BASE_URL=http://localhost:9000

# RAG plane
RAG_BASE_URL=http://localhost:8000

# Outbound events (ingestion triggers) — http or "log" for no-op
EVENTS_SINK=log
AIRFLOW_TRIGGER_URL=http://localhost:8001/api/v1/dags/mudahurus_ingest/dagRuns

# SMTP (forgot/reset password) — "log" sink prints tokens to stdout in dev
SMTP_SINK=log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@mudahurus.my

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- RAG plane (Python/FastAPI) ----
RAG_HTTP_ADDR=0.0.0.0:8000
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=mudahurus
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
LLM_PROVIDER=echo
LLM_API_KEY=
LLM_MODEL=
# Postgres for the RAG extractor (same DB)
RAG_DATABASE_URL=postgresql://mudahurus:mudahurus@localhost:5432/mudahurus

# ---- Web SPA ----
# All API routes are namespaced under /api. In dev the Vite proxy and in prod
# nginx forward /api -> the Go service, so the SPA owns /store, /invoice, /admin.
# Leave as /api (same-origin). Set a full URL only for cross-origin setups.
VITE_API_BASE_URL=/api
